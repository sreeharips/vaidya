# ─────────────────────────────────────────────────────────────────────────────
# Vaidya — Production Environment
# Copy this to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App URLs ──────────────────────────────────────────────────────────────────
# Your public domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://ayuretreats.com
# Browser-side API calls (goes through nginx → backend)
NEXT_PUBLIC_API_URL=https://ayuretreats.com

# ── Database ──────────────────────────────────────────────────────────────────
# Use Supabase or RDS in production. Example for self-hosted Docker Postgres:
POSTGRES_DB=vaidya
POSTGRES_USER=vaidya
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Full async DSN (used by FastAPI/SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://vaidya:CHANGE_ME_STRONG_PASSWORD@postgres:5432/vaidya

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_32_BYTE_HEX_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=CHANGE_ME

# ── AWS (for S3 image uploads) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=ap-south-1
AWS_S3_BUCKET=vaidya-media-prod

# ── Voice AI ──────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=CHANGE_ME
ELEVENLABS_API_KEY=CHANGE_ME
AZURE_SPEECH_KEY=CHANGE_ME
AZURE_SPEECH_REGION=eastus

# ── Misc ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
CORS_ORIGINS=https://ayuretreats.com
